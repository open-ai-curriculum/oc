{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E5C Learner State",
  "type": "object",
  "properties": {
    "learner_id": {
      "type": "string"
    },
    "node_id": {
      "const": "E5C"
    },
    "status": {
      "enum": [
        "blocked",
        "emerging",
        "provisional",
        "secure",
        "unstable"
      ]
    },
    "direct_accuracy": {
      "type": "number"
    },
    "explanation_status": {
      "enum": [
        "not_met",
        "weak",
        "met"
      ]
    },
    "transfer_status": {
      "enum": [
        "not_met",
        "weak",
        "met"
      ]
    },
    "retention_status": {
      "enum": [
        "not_due",
        "not_met",
        "met"
      ]
    },
    "dominant_failure_modes": {
      "type": "array",
      "items": {
        "enum": [
          "E5C-FM-01",
          "E5C-FM-02",
          "E5C-FM-03",
          "E5C-FM-04"
        ]
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "learner_id",
    "node_id",
    "status"
  ]
}
