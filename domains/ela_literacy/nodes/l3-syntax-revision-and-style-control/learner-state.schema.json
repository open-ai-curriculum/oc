{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L3 Learner State",
  "type": "object",
  "required": [
    "learner_id",
    "node_id",
    "status",
    "dependency_status",
    "direct_accuracy",
    "explanation_status",
    "transfer_status",
    "retention_status",
    "dominant_failure_modes",
    "recommended_interventions",
    "last_verified_at",
    "review_state",
    "notes"
  ],
  "properties": {
    "learner_id": { "type": "string" },
    "node_id": { "const": "L3" },
    "status": {
      "type": "string",
      "enum": ["blocked", "emerging", "provisional", "secure", "unstable"]
    },
    "dependency_status": {
      "type": "object",
      "required": ["L1", "L2"],
      "properties": {
        "L1": {
          "type": "string",
          "enum": ["blocked", "emerging", "provisional", "secure", "unstable"]
        },
        "L2": {
          "type": "string",
          "enum": ["blocked", "emerging", "provisional", "secure", "unstable"]
        }
      },
      "additionalProperties": false
    },
    "direct_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "explanation_status": {
      "type": "string",
      "enum": ["not_met", "weak", "met"]
    },
    "transfer_status": {
      "type": "string",
      "enum": ["not_met", "weak", "met"]
    },
    "retention_status": {
      "type": "string",
      "enum": ["not_due", "not_met", "met"]
    },
    "dominant_failure_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["L3-FM-01", "L3-FM-02", "L3-FM-03", "L3-FM-04"]
      }
    },
    "recommended_interventions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "last_verified_at": { "type": "string", "format": "date" },
    "review_state": {
      "type": "string",
      "enum": ["draft", "human-reviewed"]
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
