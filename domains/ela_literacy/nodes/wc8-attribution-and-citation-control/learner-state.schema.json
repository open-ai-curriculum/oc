{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WC8 Learner State",
  "type": "object",
  "required": [
    "learner_id",
    "node_id",
    "status",
    "dependency_status",
    "direct_accuracy",
    "explanation_status",
    "transfer_status",
    "retention_status",
    "dominant_failure_modes",
    "recommended_interventions",
    "last_verified_at",
    "review_state",
    "notes"
  ],
  "properties": {
    "learner_id": {
      "type": "string"
    },
    "node_id": {
      "const": "WC8"
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked",
        "emerging",
        "provisional",
        "secure",
        "unstable"
      ]
    },
    "dependency_status": {
      "type": "object",
      "properties": {
        "WC7": {
          "type": "string",
          "enum": [
            "blocked",
            "emerging",
            "provisional",
            "secure",
            "unstable"
          ]
        },
        "L3": {
          "type": "string",
          "enum": [
            "blocked",
            "emerging",
            "provisional",
            "secure",
            "unstable"
          ]
        }
      },
      "required": [
        "WC7",
        "L3"
      ]
    },
    "direct_accuracy": {
      "type": "number"
    },
    "explanation_status": {
      "type": "string",
      "enum": [
        "not_met",
        "weak",
        "met"
      ]
    },
    "transfer_status": {
      "type": "string",
      "enum": [
        "not_met",
        "weak",
        "met"
      ]
    },
    "retention_status": {
      "type": "string",
      "enum": [
        "not_due",
        "not_met",
        "met"
      ]
    },
    "dominant_failure_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "WC8-FM-01",
          "WC8-FM-02",
          "WC8-FM-03",
          "WC8-FM-04"
        ]
      }
    },
    "recommended_interventions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string"
    },
    "review_state": {
      "type": "string",
      "enum": [
        "draft",
        "human-reviewed"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
