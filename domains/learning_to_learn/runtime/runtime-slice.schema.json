{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ai-curriculum.local/domains/learning_to_learn/runtime/runtime-slice.schema.json",
  "title": "Learning-To-Learn Runtime Slice",
  "type": "object",
  "required": ["slice_id", "domain", "status", "version", "node_ids", "entry_node_ids", "learner_state_fields", "navigation_rules"],
  "properties": {
    "slice_id": { "type": "string" },
    "domain": { "const": "learning_to_learn" },
    "status": { "type": "string", "enum": ["draft", "review", "approved"] },
    "version": { "type": "string" },
    "node_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "entry_node_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "learner_state_fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "navigation_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "decision_type", "applies_when", "outcome"],
        "properties": {
          "rule_id": { "type": "string" },
          "decision_type": {
            "type": "string",
            "enum": ["teach_next", "hold_current", "route_upstream", "reverify", "accelerate", "route_human_review"]
          },
          "applies_when": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "outcome": { "type": "string" },
          "artifact_selection": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifact_registry_reference": { "type": "string" },
    "review_status": { "type": "string", "enum": ["draft", "review", "approved"] }
  },
  "additionalProperties": false
}
