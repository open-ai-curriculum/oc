{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "X5LearnerState",
  "type": "object",
  "required": [
    "student_id",
    "node",
    "status"
  ],
  "properties": {
    "student_id": {
      "type": "string"
    },
    "node": {
      "const": "X5"
    },
    "status": {
      "type": "string"
    },
    "direct_accuracy": {
      "type": "number"
    },
    "explanation_status": {
      "type": "string"
    },
    "transfer_status": {
      "type": "string"
    },
    "retention_status": {
      "type": "string"
    },
    "dominant_failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_interventions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
